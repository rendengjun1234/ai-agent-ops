generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model PlatformAccount {
  id          String   @id @default(cuid())
  platform    String
  accountId   String
  accountName String
  cookies     String
  status      String   @default("active")
  bindTime    DateTime @default(now())
  lastSyncAt  DateTime?
  shops       Shop[]

  @@unique([platform, accountId])
}

model Shop {
  id          String   @id @default(cuid())
  shopId      String
  shopName    String
  platform    String
  address     String?
  rating      Float?
  accountId   String
  account     PlatformAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  reviews     Review[]

  @@unique([platform, shopId])
}

model Review {
  id          String   @id @default(cuid())
  reviewId    String
  platform    String
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  userName    String
  rating      Int
  content     String
  images      String?
  hasVideo    Boolean  @default(false)
  createdAt   DateTime
  reply       String?
  repliedAt   DateTime?
  syncedAt    DateTime @default(now())

  // AI分析字段
  aiTags         String?
  riskLevel      String?
  aiSummary      String?
  aiReply        String?
  rootCause      String?
  mentionedDish  String?
  mentionedStaff String?
  mentionedPeriod String?
  status         String  @default("pending")
  assignee       String?
  isHighValue    Boolean @default(false)
  linkedTaskId   String?

  @@unique([platform, reviewId])
}

model RemediationTask {
  id                String    @id @default(cuid())
  title             String
  category          String
  sourceReviewCount Int       @default(0)
  stores            String
  riskLevel         String
  assignee          String
  deadline          String
  status            String    @default("open")
  suggestedAction   String
  period            String?
  staff             String?
  createdAt         DateTime  @default(now())
  resolvedAt        DateTime?
  scoreImpact       String?
}

model SyncTask {
  id          String   @id @default(cuid())
  platform    String
  accountId   String
  taskType    String
  status      String   @default("pending")
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  createdAt   DateTime @default(now())
}
